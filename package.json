{
  "name": "formicarium",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:wasm": "node scripts/build-wasm.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:monitor": "vitest run --config vitest.monitor.config.ts tests/_monitor.test.ts --testTimeout=7200000",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "assemblyscript": "^0.28.16",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
